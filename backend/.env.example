PORT=4001
JWT_SECRET=cambia-este-valor-por-un-secreto-largo-y-aleatorio

# Desarrollo local: se usa un archivo SQLite local en DB_PATH (no requiere cuenta de Turso).
DB_PATH=./data/lumilab.db

# Produccion: si defines estas dos, la base de datos vive en Turso (libSQL remoto) en vez
# del archivo local, y persiste aunque el servicio se reinicie. Se obtienen desde
# https://turso.tech tras crear una base de datos gratuita.
# TURSO_DATABASE_URL=libsql://tu-base-tu-usuario.turso.io
# TURSO_AUTH_TOKEN=
